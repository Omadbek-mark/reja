<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet"/>
  <script src="//maxcdn.bootstrapcdn.com/bootstrap/4.1.1/js/bootstrap.min.js"></script>
  <title>Portfolio</title>
  <link rel="stylesheet" href="/main.css">
</head>

<body>
  <div class="frame">
    <div class="main_frame">
      <div class="left_frame">
        <div class="left-1">
          <div class="left-1-1">
            <img class="profile-pic"
             src="images/profile_pic.jpg"
             width="156px"
             height="150px"
             alt="">
          </div>
          <div class="left-1-2"><%= user.name%></div>
          <div class="left-1-3"><%= user.profession%></div>
          <div class="left-icons">
            <a class="link_href" href="">
              <div class="icon">
                <img src="icon/Facebook.svg" class="icon-1" />
              </div>
            </a>
            <a class="link_href" href="">
                <div class="icon">
                    <img src="icon/Instagram.svg" class="icon-1" />
                </div>
            </a>
             <a class="link_href" href="">
              <div class="icon">
                <img src="icon/Twitter.svg" class="icon-1" />
              </div>
            </a>
            <a class="link_href" href="">
                <div class="icon">
                    <img src="icon/Linkeding.svg" class="icon-1" />
                </div>
            </a>
            <a class="link_href" href="">
              <div class="icon">
                <img src="icon/Youtube.svg" class="icon-1" />
              </div>
            </a>
            
           
          </div>
        </div>
        <div class="marginer"></div>
        <div class="left-2">
          <div class="info-item"><span>Age:</span><%= user.age%></div>
          <div class="info-item"><span>Residence:</span><%= user.residence%></div>
          <div class="info-item"><span>Freelance:</span> <span class="available">Available</span></div>
          <div class="info-item"><span>Address:</span><%= user.adress%></div>
        </div>
        <div class="marginer"></div>
        <div class="left-3">
            <h3>Languages</h3>
            
            <% user.languages.forEach(function(lang) { %>
                <div class="language-item">
                    <div class="lang-info">
                        <span class="lang-name"><%= lang.name %></span>
                        <span class="lang-percentage"><%= lang.level %></span>
                    </div>
                    <div class="progress-bar-wrapper">
                      <div class="progress-fill" style="width:  <%= lang.level %>";></div>
                    </div>
                </div>
            <% }); %>
        </div>
        <div class="marginer"></div>
        <div class="left-4">
            <h3>Skills</h3>
            
            <% user.skills.forEach(function(skill) { %>
                <div class="skill-item">
                    <div class="skill-info">
                        <span class="skill-name text-muted"><%= skill.name %></span>
                        <span class="skill-percentage text-muted"><%= skill.level %></span>
                    </div>
                    <div class="progress-bar-wrapper">
                        <div class="progress-fill" style="width: <%= skill.level %>";></div>
                    </div>
                </div>
            <% }); %>
        </div>
        <div class="marginer"></div>
        <div class="left-5">
          <div class="extra-skills-container">
              <h3>Extra Skills</h3>
              
              <% user.extra_skills.forEach(function(skill) { %>
                  <div class="extra-skill-item">
                      <div class="custom-icon">
                          <div class="rect-1"></div>
                          <div class="rect-2"></div>
                      </div>
                      <span class="skill-text"><%= skill %></span>
                  </div>
              <% }); %>
          </div>
        </div>
        <div class="marginer"></div>
      </div>
       <div class="midd-frame">
           <div class="intro">
            <h1 class="Doctor"></h1>
            <p></p>
            <button class="hire-btn"></button>
           </div>

           <section class="services-section">
                <div class="header-content">
                    <h2>My Services</h2>
                    <p>Amet Minim Mollit Non Deserunt Ullamco Est Sit Aliqua Dolor <br> 
                    Do Amet Sint. Velit Officia Consequat Duis Enim Velit Mollit. <br>
                    Lorem Ipsum</p>
                </div>

                <div class="services-grid">
                    <div class="service-card">
                        <img class="web-icon" src="icon/Icons_coding.svg" alt="">
                        <h3>Web Development</h3>
                        <p>Blog, E-Commerce</p>
                    </div>

                    <div class="service-card">   
                            <img class="web-icon" src="icon/Icons_Illustration.png" alt="">
                        <h3>UI/UX Design</h3>
                        <p>Mobile App, Website Design</p>
                    </div>

                    <div class="service-card">
                           <img class="web-icon" src="icon/Icons_Microphone.png" alt="">

                        <h3>Sound Design</h3>
                        <p>Voice Over, Beat Making</p>
                    </div>

                    <div class="service-card">
                        <img class="web-icon" src="icon/Icons_game-development.png" alt="">
                        <h3>Game Design</h3>
                        <p>Character Design, Props & Objects</p>
                    </div>

                    <div class="service-card">
                         <img class="web-icon" src="icon/Icons_Photographer.png" alt="">
                      <h3>Photography</h3>
                      <p>Portrait, Product Photography</p>
                    </div>

                    <div class="service-card advertising">
                        <h3>Advertising</h3>
                        <p>Lorem Ipsum Dolor Sit Amet, Consectetur Adipiscing Elit. Vitae Nulla Diam In Ac Dictum A Urna Viverra Morbi.</p>
                        <a href="#" class="order-btn">ORDER NOW ></a>
                    </div>
                </div>
            </section>
        </div>
      <div class="right_frame"></div>

    </div>
  </div>
</body>

</html>