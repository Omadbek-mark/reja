<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet"/>
  <script src="//maxcdn.bootstrapcdn.com/bootstrap/4.1.1/js/bootstrap.min.js"></script>
  <title>Portfolio</title>
  <link rel="stylesheet" href="/main.css">
</head>

<body>
  <div class="frame">
    <div class="main_frame">
      <div class="left_frame">
        <div class="left-1">
          <div class="left-1-1">
            <img class="profile-pic"
                src="images/profile_pic.jpg"
                width="156px"
                height="150px"
                alt="">
          </div>
          <div class="left-1-2"><%= user.name%></div>
          <div class="left-1-3"><%= user.profession%></div>
          <div class="left-icons">
            <a href="#">
              <div class="icon">
                <img src="icon/Facebook.svg" class="icon-1" />
              </div>
            </a>
            <a href="#">
                <div class="icon">
                    <img src="icon/Instagram.svg" class="icon-1" />
                </div>
            </a>

             <a href="#">
              <div class="icon">
                <img src="icon/Twitter.svg" class="icon-1" />
              </div>
            </a>
            
            <a href="#">
                <div class="icon">
                    <img src="icon/Linkeding.svg" class="icon-1" />
                </div>
            </a>
            <a href="#">
              <div class="icon">
                <img src="icon/Youtube.svg" class="icon-1" />
              </div>
            </a>
            
          </div>
        </div>
        <div class="marginer"></div>

        <div class="left-2">
          <div class="info"><span>Age:</span><%= user.age%></div>
          <div class="info"><span>Residence:</span><%= user.residence%></div>
          <div class="info"><span>Freelance:</span> <span class="available">Available</span></div>
          <div class="info"><span>Address:</span><%= user.adress%></div>
        </div>

         <div class="marginer"></div>

        <div class="left-3">
            <h3>Languages</h3>
            
            <% user.languages.forEach(function(lang) { %>
                <div class="language">
                    <div class="lang-info">
                        <span class="lang-name"><%= lang.name %></span>
                        <span class="lang-per"><%= lang.level %></span>
                    </div>
                    <div class="progress-bar-wrapper">
                      <div class="progress-fill" style="width: <%= lang.level %>"></div>
                    </div>
                </div>
            <% }); %>
        </div>
        <div class="marginer"></div>
        <div class="left-4">
            <h3>Skills</h3>

            <% user.skills.forEach(function(skill) { %>
                <div class="skill-item">
                    <div class="skill-info">
                        <span class="skill-name text-muted"><%= skill.name %></span>
                        <span class="skill-percentage text-muted"><%= skill.level %></span>
                    </div>
                    <div class="progress-bar-wrapper">
                        <div class="progress-fill" style="width: <%= skill.level %>"></div>
                    </div>
                </div>
            <% }); %>
        </div>
        <div class="marginer"></div>
        <div class="left-5">
          <div class="extra-skills-container">
              <h3>Extra Skills</h3>
              
              <% user.extra_skills.forEach(function(skill) { %>
                  <div class="extra-skill-item">
                      <div class="custom-icon">
                          <div class="rect-1"></div>
                          <div class="rect-2"></div>
                      </div>
                      <span class="skill-text"><%= skill %></span>
                  </div>
              <% }); %>
          </div>
        </div>
       <div class="marginer"></div>
      </div>
       <div class="midd-frame">
           <section class="about-hero">
              <div class="desc-hero">
                <h1>Learning IT skills <br> at Devex Academy
                </h1>
                <p>
                  Lorem ipsum dolor sit amet, consectetur adipiscing elit. 
                  Et, volutpat feugiat placerat lobortis. Natoque rutrum 
                  semper sed suspendisse nunc lectus.
                </p>
                <button class="hire-btn">HIRE ME</button>
              </div>

              <div class="hero-image">
                <img src="images/photo_mark.jpg" alt="">
                <span class="shape circle-orange"></span>
                <span class="shape triangle-red"></span>
              </div>
           </section>

           <section class="services-section">
                <div class="header-content">
                    <h2>My Services</h2>
                    <p>Amet Minim Mollit Non Deserunt Ullamco Est Sit Aliqua Dolor <br> 
                    Do Amet Sint. Velit Officia Consequat Duis Enim Velit Mollit. <br>
                    Lorem Ipsum</p>
                </div>

                <div class="services-grid">
                    <div class="service-card">
                        <img class="web-icon" src="menu-icons/Icons_coding.svg" alt="">
                        <h3>Web Development</h3>
                        <p>Blog, E-Commerce</p>
                    </div>

                    <div class="service-card">   
                            <img class="web-icon" src="menu-icons/Icons_Illustration.png" alt="">
                        <h3>UI/UX Design</h3>
                        <p>Mobile App, Website Design</p>
                    </div>

                    <div class="service-card">
                           <img class="web-icon" src="menu-icons/Icons_Microphone.png" alt="">

                        <h3>Sound Design</h3>
                        <p>Voice Over, Beat Making</p>
                    </div>

                    <div class="service-card">
                        <img class="web-icon" src="menu-icons/Icons_game-development.png" alt="">
                        <h3>Game Design</h3>
                        <p>Character Design, Props & Objects</p>
                    </div>

                    <div class="service-card">
                         <img class="web-icon" src="menu-icons/Icons_Photographer.png" alt="">
                      <h3>Photography</h3>
                      <p>Portrait, Product Photography</p>
                    </div>

                    <div class="service-card advertising">
                        <h3>Advertising</h3>
                        <p>Lorem Ipsum Dolor Sit Amet, Consectetur Adipiscing Elit. Vitae Nulla Diam In Ac Dictum A Urna Viverra Morbi.</p>
                        <a href="#" class="order-btn">ORDER NOW ></a>
                    </div>
                </div>
            </section>
        </div>
      <div class="right_frame">
        <button class="switch_btn"><img src="btn_icon/Icons_Contrast.png" width="30px" height="30px"></button>
        <div class="menu_btns_container">
          <div class="home_btn_container">
            <img src="btn_icon/Pop up.png" width="65px" height="33px">
            <button class="menu_btn"><img src="btn_icon/Icons_Home.svg"></button>
          </div>
          <button class="menu_btn"><img src="btn_icon/file-code.png"></button>
          <button class="menu_btn"><img src="btn_icon/Icons_cv.png"></button>
          <button class="menu_btn"><img src="btn_icon/Vector.png"></button>
          <button class="menu_btn"><img src="btn_icon/Icons_Blog.png"></button>
          <button class="menu_btn"><img src="btn_icon/Icons_Contact.png"></button>
      </div>

    </div>
  </div>
</body>

</html>